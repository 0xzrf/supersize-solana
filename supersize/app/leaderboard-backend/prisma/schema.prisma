generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  walletAddress String @id
  name          String?
  winning       Winning[]
}

model Winning {
  userWalletAddress String @id
  usdc          Int @default(0)
  sol           Int @default(0)
  agld          Int @default(0)
  user          User @relation(fields: [userWalletAddress], references: [walletAddress])
}
